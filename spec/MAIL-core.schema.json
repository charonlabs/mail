{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charonlabs/mail/spec/MAIL-core.schema.json",
  "title": "MAIL Core Schema",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/MAILMessage" }
  ],
  "$defs": {
    "MAILAddress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["addr_type", "address"],
      "properties": {
        "addr_type": {
          "type": "string",
          "enum": ["admin","agent", "user", "system"]
        },
        "address": { 
          "type": "string", 
          "minLength": 1 
        }
      }
    },
    "MAILMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", 
        "timestamp", 
        "msg_type", 
        "sender", 
        "recipients", 
        "subject", 
        "body", 
        "task_id", 
        "metadata"
      ],
      "properties": {
        "id": { 
          "type": "string", 
          "format": "uuid" 
        },
        "timestamp": { 
          "type": "string", 
          "format": "date-time" 
        },
        "msg_type": {
          "type": "string",
          "enum": ["direct", "broadcast", "interrupt", "task_complete"]
        },
        "sender": {
          "$ref": "#/$defs/MAILAddress"
        },
        "recipients": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/MAILAddress"
          },
          "additionalItems": false
        },
        "subject": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "task_id": {
          "type": "string",
          "format": "uuid"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "MAILTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "task_owner", "task_contributors", "start_time", "completed", "messages", "metadata"],
      "properties": {
        "task_id": {
          "type": "string",
          "format": "uuid"
        },
        "task_owner": {
          "$ref": "#/$defs/MAILInstance"
        },
        "task_contributors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/MAILInstance"
          },
          "additionalItems": false
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "completed": {
          "type": "boolean"
        },
        "messages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MAILMessage"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "MAILInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instance_type", "instance_client_id", "swarm_name"],
      "properties": {
        "instance_type": {
          "type": "string",
          "enum": ["admin", "user", "swarm"]
        },
        "instance_client_id": {
          "type": "string"
        },
        "swarm_name": {
          "type": "string"
        }
      }
    },
    "MAILServerSentEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "data"],
      "properties": {
        "event": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
