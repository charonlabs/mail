{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charonlabs/mail/spec/MAIL-interswarm.schema.json",
  "title": "MAIL Interswarm Schema",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/MAILMessage" }
  ],
  "$defs": {
    "MAILInterswarmMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interswarm_message_id",
        "source_swarm",
        "target_swarm",
        "timestamp",
        "payload",
        "task",
        "attachments",
        "metadata"
      ],
      "properties": {
        "interswarm_message_id": { 
          "type": "string", 
          "format": "uuid"
        },
        "source_swarm": { 
          "type": "string", 
          "minLength": 1 
        },
        "target_swarm": { 
          "type": "string", 
          "minLength": 1 
        },
        "timestamp": { 
          "type": "string", 
          "format": "date-time" 
        },
        "task": {
          "$ref": "#/$defs/MAILInterswarmTask"
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MAILInterswarmAttachment"
          }
        },
        "metadata": { 
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "MAILInterswarmTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "task_owner", "task_contributors", "start_time", "completed", "metadata"],
      "properties": {
        "task_id": {
          "type": "string",
          "format": "uuid"
        },
        "task_owner": {
          "$ref": "MAIL-core.schema.json#/$defs/MAILInstance"
        },
        "task_contributors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { 
            "$ref": "MAIL-core.schema.json#/$defs/MAILInstance" 
          },
          "additionalItems": false
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "completed": {
          "type": "boolean"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "MAILInterswarmAttachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attachment_name", "attachment_type", "attachment_data", "metadata"],
      "properties": {
        "attachment_name": {
          "type": "string",
          "minLength": 1
        },
        "attachment_type": {
          "type": "string",
          "format": "mime-type"
        },
        "attachment_data": {
          "type": "string",
          "format": "base64"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "MAILRemoteSwarm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "base_url", "protocol_version", "active", "last_seen", "description", "keywords", "metadata"],
      "properties": {
        "name": { 
          "type": "string",
          "minLength": 1
        },
        "base_url": { 
          "type": "string",
          "format": "uri" 
        },
        "protocol_version": { 
          "type": "string",
          "enum": ["2.0"]
        },
        "active": { 
          "type": "boolean" 
        },
        "last_seen": { 
          "type": "string", 
          "format": "date-time", 
          "nullable": true 
        },
        "description": { 
          "type": "string", 
          "nullable": true 
        },
        "keywords": { 
          "type": "array", 
          "items": { 
            "type": "string" 
          }, 
          "nullable": true 
        },
        "metadata": { 
          "type": "object", 
          "additionalProperties": true
        }
      }
    }
  }
}
